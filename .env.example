# ─────────────────────────────────────────────────────────────
# VAgeWell Care — environment template (placeholders only)
# Copy to `frontend/.env.local` (NEXT_PUBLIC_* vars) and set the
# Edge Function secrets with `supabase secrets set ...`.
# NEVER commit real values.
# ─────────────────────────────────────────────────────────────

# ── Frontend (browser-exposed — the ONLY NEXT_PUBLIC_* vars) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Supabase Edge Function secrets (server-side only) ─────────
# Set via:  supabase secrets set NOTIFY_EMAIL_TO=... EMAIL_API_KEY=...
NOTIFY_EMAIL_TO=maheshwari21102003@gmail.com
EMAIL_FROM=alerts@vagewell.example
EMAIL_PROVIDER=dev            # dev | resend | sendgrid   (dev => log only, no send)
EMAIL_API_KEY=your_email_api_key_here
# Shared secret the DB webhook must send as `x-webhook-secret` (blocks URL spoofing).
# When unset, the function accepts unauthenticated calls (dev only).
NOTIFY_WEBHOOK_SECRET=your_webhook_secret_here
SUPABASE_URL=https://your-project.supabase.co          # injected automatically in deployed fns
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # injected automatically in deployed fns

# ── SMS / OTP (configured in the Supabase Auth dashboard, NOT the app) ──
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_MESSAGING_SERVICE_SID=...
